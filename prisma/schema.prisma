generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Room {
  id        String   @id
  hostId    String
  settings  Json
  createdAt DateTime @default(now())
  hands     Hand[]
}

model Hand {
  id        String   @id
  roomId    String
  replay    Json
  result    Json?
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id])
}
